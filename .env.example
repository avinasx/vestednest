# Supabase — https://supabase.com/docs/guides/api/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
# Server-side only (never expose to client):
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Superadmin auto-promotion on Google sign-in (comma-separated emails)
SUPERADMIN_EMAILS=you@yourcompany.com

# Realie Property Data API — https://docs.realie.ai/introduction
REALIE_API_KEY=your_realie_api_key

# Google Gemini — Nest AI chat (LangGraph)
GOOGLE_API_KEY=your_gemini_api_key
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-1.5-flash

# Supermemory — conversation memory + knowledge base sync
# https://github.com/supermemoryai/sdk-ts
SUPERMEMORY_API_KEY=your_supermemory_api_key

# RentCast — rent comps enrichment
# https://developers.rentcast.io/reference/introduction
RENTCAST_API_KEY=your_rentcast_api_key

# SendGrid — term sheet email delivery
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=quotes@yourdomain.com

# Twilio — call transfer to loan officers (optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Credit vendor — soft pull integration (optional)
CREDIT_VENDOR_API_KEY=your_credit_vendor_key

# App URL for Twilio webhooks (production)
NEXT_PUBLIC_APP_URL=https://yourdomain.com
