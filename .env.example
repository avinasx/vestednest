# Supabase (vestednest) — https://supabase.com/docs/guides/api/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://axtzwpoosurrtmhidbsm.supabase.co
# Recommended: publishable key (sb_publishable_...) from Dashboard → Settings → API Keys
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# Legacy fallback only (deprecated; works until ~end of 2026):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_jwt

# Realie Property Data API — https://docs.realie.ai/introduction
REALIE_API_KEY=your_realie_api_key

# Google Gemini — Nest AI chat (LangGraph)
GOOGLE_API_KEY=your_gemini_api_key
GEMINI_API_KEY=your_gemini_api_key
# Optional model override (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Supermemory — https://github.com/supermemoryai/sdk-ts
SUPERMEMORY_API_KEY=your_supermemory_api_key
