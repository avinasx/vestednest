# =========================================
# Vested Nest — Infrastructure only
# =========================================
# All integration config: Admin → Settings → Integrations (platform_settings).
# Run once after clone: npm run seed:platform-settings

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — https://supabase.com/docs/guides/api/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
# Server-side only (never expose to client):
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Superadmin auto-promotion on Google sign-in (comma-separated emails)
SUPERADMIN_EMAILS=you@yourcompany.com

# Optional: import into platform_settings via seed script or admin UI
# REALIE_API_KEY=
# RENTCAST_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# SUPERMEMORY_API_KEY=
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=quotes@vestednest.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# CREDIT_VENDOR_API_KEY=
