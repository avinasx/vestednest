# =============================================================================
# Vested Nest — environment variable placement
# =============================================================================
#
# | Where              | What |
# |--------------------|------|
# | Vercel (A)         | Supabase URL/keys, superadmin emails — deploy infra only |
# | platform_settings  | Integration API keys — Admin → Settings → Integrations |
# | GitHub Actions (C) | SUPABASE_DB_URL only — CI migrations |
# | .env.local (D)     | Gitignored: all of A + B values for local dev / seed script |
#
# Production integrations are NOT stored in GitHub or Vercel env.
# After clone: copy to .env.local, then `npm run seed:platform-settings` once.
# See PRODUCTION.md for the full secrets matrix.

NODE_ENV=development

# -----------------------------------------------------------------------------
# A) Vercel only — infrastructure (never GitHub, never platform_settings)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
# Server-side only (never expose to client):
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Comma-separated emails auto-promoted to superadmin on Google sign-in
SUPERADMIN_EMAILS=you@yourcompany.com

# -----------------------------------------------------------------------------
# B) platform_settings — optional in .env.local for seed / local dev fallback
# Editable in production via Admin → Settings → Integrations
# Maps to lib/platform/setting-definitions.ts
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=          # ai.gemini_api_key (GOOGLE_API_KEY also accepted)
# GEMINI_MODEL=gemini-3.1-flash-lite
# LANGSMITH_API_KEY=       # ai.langsmith_api_key (enables LANGSMITH_TRACING when set)
# REALIE_API_KEY=          # data.realie_api_key
# RENTCAST_API_KEY=        # data.rentcast_api_key
# SUPERMEMORY_API_KEY=     # memory.supermemory_api_key
# SENDGRID_API_KEY=        # email.sendgrid_api_key
# SENDGRID_FROM_EMAIL=quotes@vestednest.com
# TWILIO_ACCOUNT_SID=      # twilio.account_sid
# TWILIO_AUTH_TOKEN=       # twilio.auth_token
# TWILIO_PHONE_NUMBER=     # twilio.phone_number
# CREDIT_VENDOR_API_KEY=   # credit.vendor_api_key

# -----------------------------------------------------------------------------
# C) GitHub Actions only — not needed in Vercel or .env.local unless local push
# Session pooler URI (IPv4); see PRODUCTION.md
# -----------------------------------------------------------------------------
# SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
